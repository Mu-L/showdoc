{
  "openapi": "3.0.3",
  "info": {
    "title": "RunAPI Import Probe OpenAPI3 Inline",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://{{manage}}"
    }
  ],
  "paths": {
